#!/bin/bash

# Change ensemble run in file (M1-M10)
# CMIP6, SMBb: HIST (1990-2014), SSP370 (2015-2100)
# sst wget and year_mon
# wget "https://data-osdf.rda.ucar.edu/ncar/rda/d651056/CESM2-LE/ocn/proc/tseries/month_1/SST/b.e21.BHISTsmbb.f09_g17.LE2-1051.003.pop.h.SST.185001-185912.nc"

# Define arrays outside loops
cmip6_members=(1001.001 1021.002 1041.003 1061.004 1081.005 1101.006 1121.007 1141.008 1161.009 1181.010 \
              1231.001 1231.002 1231.003 1231.004 1231.005 1231.006 1231.007 1231.008 1231.009 1231.010 \
              1251.001 1251.002 1251.003 1251.004 1251.005 1251.006 1251.007 1251.008 1251.009 1251.010 \
              1281.001 1281.002 1281.003 1281.004 1281.005 1281.006 1281.007 1281.008 1281.009 1281.010 \
              1301.001 1301.002 1301.003 1301.004 1301.005 1301.006 1301.007 1301.008 1301.009 1301.010)

smbb_members=(1231.011 1231.012 1231.013 1231.014 1231.015 1231.016 1231.017 1231.018 1231.019 1231.020 \
              1251.011 1251.012 1251.013 1251.014 1251.015 1251.016 1251.017 1251.018 1251.019 1251.020 \
              1281.011 1281.012 1281.013 1281.014 1281.015 1281.016 1281.017 1281.018 1281.019 1281.020 \
              1301.011 1301.012 1301.013 1301.014 1301.015 1301.016 1301.017 1301.018 1301.019 1301.020 \
              1011.001 1031.002 1051.003 1071.004 1091.005 1111.006 1131.007 1151.008 1171.009 1191.010)

hist_startyears=(1990 2000 2010)
hist_endyears=(1999 2009 2014)
ssp_startyears=(2015 2025 2035 2045 2055 2065 2075 2085 2095)
ssp_endyears=(2024 2034 2044 2054 2064 2074 2084 2094 2100)

process_member() {
    local memberno=$1
    local label=$2

    # HIST runs
    for j in {0..2}; do
        startyear=${hist_startyears[j]}
        endyear=${hist_endyears[j]}
    
        #uwind
        wget "https://data-osdf.rda.ucar.edu/ncar/rda/d651056/CESM2-LE/ocn/proc/tseries/month_1/SST/b.e21.BHIST${label}.f09_g17.LE2-${memberno}.pop.h.SST.${startyear}01-${endyear}12.nc"
        
        filename="b.e21.BHIST${label}.f09_g17.LE2-${memberno}.cam.h0.SST.${startyear}01-${endyear}12.nc.1"
        if [[ -f "$filename" ]]; then
            # Remove the .1 suffix
            new_filename="${filename%.1}"
            mv "$filename" "$new_filename"  # Rename the file
            filename="$new_filename"  # Update the filename variable
        fi

        mv /home/elic/lhoffman/cnn_slowdown/b.e21.BHIST${label}.f09_g17.LE2-${memberno}.pop.h.SST.${startyear}01-${endyear}12.nc /cofast/lhoffman/cesmle/sst/raw/
        
    done

    # SSP370 runs
    for j in {0..8}; do
        startyear=${ssp_startyears[j]}
        endyear=${ssp_endyears[j]}

        # download uwind
        wget "https://data-osdf.rda.ucar.edu/ncar/rda/d651056/CESM2-LE/ocn/proc/tseries/month_1/SST/b.e21.BSSP370${label}.f09_g17.LE2-${memberno}.pop.h.SST.${startyear}01-${endyear}12.nc"
        
        filename="b.e21.SSP370${label}.f09_g17.LE2-${memberno}.pop.h.SST.${startyear}01-${endyear}12.nc.1"
        if [[ -f "$filename" ]]; then
            # Remove the .1 suffix
            new_filename="${filename%.1}"
            mv "$filename" "$new_filename"  # Rename the file
            filename="$new_filename"  # Update the filename variable
        fi

        mv /home/elic/lhoffman/cnn_slowdown/b.e21.BSSP370${label}.f09_g17.LE2-${memberno}.pop.h.SST.${startyear}01-${endyear}12.nc /cofast/lhoffman/cesmle/sst/raw/

    done
}

# Run for CMIP6 members
for member in "${cmip6_members[@]}"; do
    process_member $member "cmip6"
done

# Run for SMBb members
for member in "${smbb_members[@]}"; do
    process_member $member "smbb"
done
